{
  "name": "vertical-scrolling-shooter",
  "version": "1.0.0",
  "description": "A browser-based vertical scrolling shooting game built with vanilla JavaScript and Canvas API",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite --open",
    "play": "npm run dev",
    "quick-start": "npm install && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "generate-audio": "node generate_audio.cjs",
    "generate-audio:gcp": "node generate_audio_gcp.js"
  },
  "keywords": [
    "game",
    "shooting",
    "canvas",
    "javascript",
    "browser-game"
  ],
  "author": "AI Agent",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.8.1"
  },
  "devDependencies": {
    "@vitest/ui": "^4.0.15",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "happy-dom": "^20.0.11",
    "prettier": "^3.1.0",
    "terser": "^5.44.1",
    "vite": "^5.0.0",
    "vitest": "^4.0.15"
  }
}
