{
  "name": "space-shooter-game",
  "version": "1.0.0",
  "description": "HTML5 Canvas-based Space Shooter Game",
  "main": "src/index.html",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:core": "jest tests/core",
    "start": "node server.js",
    "dev": "node server.js",
    "serve": "node server.js",
    "generate-audio:gcp": "node generate_audio_gcp.js",
    "generate-audio:install": "npm install --no-save @google-cloud/text-to-speech"
  },
  "keywords": [
    "game",
    "space-shooter",
    "canvas",
    "html5"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "canvas": "^2.11.2",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  }
}